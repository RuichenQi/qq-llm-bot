# Secrets — NEVER commit
.env
.env.*
!.env.example

# Runtime state
data/state.db
data/state.db-wal
data/state.db-shm
data/memory.json
data/quota.json
data/*.migrated
data/images/
data/logs/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Editor
.vscode/
.idea/
.claude/
*.swp

# Third-party binaries (NapCat / QQ NT) — install locally, don't commit
NapCat.Shell.*/
NapCat.*.Shell/
NapCat.Framework*/
napcat/
*.exe
*.dll
*.deb
