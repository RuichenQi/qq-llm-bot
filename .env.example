# ===== LLM providers =====
DEEPSEEK_API_KEY=sk-deepseek-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

OPENAI_API_KEY=sk-openai-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
# gpt-image-2 (2026-04): native reasoning, 2K-capable, best current quality.
# Cheaper fallbacks: gpt-image-1 (~$0.01-0.04), gpt-image-1-mini low ($0.005), dall-e-2 ($0.016 at 256x256).
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
# gpt-image-* only: low | medium | high | auto.
OPENAI_IMAGE_QUALITY=low
# Uploaded images are downscaled to fit within this box (px) before vision.
# 512 is the sweet spot — fits one OpenAI "low detail" tile (flat 85 tokens =
# ~$0.000013 per call regardless of input size). Going smaller (e.g. 128) does
# NOT save tokens because low-detail is flat-priced; below ~256 the model
# often refuses with "I can't view images".
MAX_VISION_INPUT_SIZE=512

# ===== OneBot v11 (NapCatQQ / Lagrange) =====
# Two modes:
#   forward  — the bot connects out to ONEBOT_WS_URL exposed by the adapter.
#   reverse  — the bot runs a WS server; the adapter connects in. NapCat default.
ONEBOT_MODE=forward
ONEBOT_WS_URL=ws://127.0.0.1:3001
ONEBOT_ACCESS_TOKEN=

# Used only when ONEBOT_MODE=reverse:
ONEBOT_REVERSE_HOST=0.0.0.0
ONEBOT_REVERSE_PORT=3001
ONEBOT_REVERSE_PATH=/onebot/v11/ws

# ===== Trigger mode =====
# always  — reply to every group message (commands always work)
# mention — only when the bot is @ed
# prefix  — only when the message starts with TRIGGER_PREFIX
TRIGGER_MODE=always
TRIGGER_PREFIX=#

# ===== Ambient engagement =====
# Three tiers for non-addressed chat. The router picks high vs low; the
# handler then re-classifies "high + looks like a question" → "question" so
# the bot doesn't butt into questions aimed at someone else.
#   high     = clear hook, NOT a question ("我今天累炸了" / "刚发现一家新店")
#   question = looks like a question (?/？ or 吗/呢/么/嘛 ending or 为啥/咋办...)
#              — usually aimed at one specific other user
#   low      = reactions ("666"/"嗯"), banter, off-topic, rants
# Roll the matching probability before replying. All tiers share the cooldown.
# Directly-addressed messages (@bot / nickname) bypass ALL of these gates.
AMBIENT_REPLY_PROBABILITY_HIGH=0.01
AMBIENT_REPLY_PROBABILITY_QUESTION=0.005
AMBIENT_REPLY_PROBABILITY_LOW=0.0001
AMBIENT_REPLY_MIN_SECONDS=120

# How long (seconds) to keep downloaded image bytes around so /edit and /vision
# can reuse them without re-downloading from QQ (whose URLs may expire).
# Files are persisted to data/images/ and swept on a 10-minute interval.
IMAGE_CACHE_TTL=600

# ===== Streaming =====
# Stream DeepSeek replies into QQ in chunks. Disable on flaky networks.
STREAM_REPLIES=1
STREAM_FLUSH_CHARS=220

# ===== Daily report =====
# Set this to a QQ group id and the bot will post today's usage there at the
# configured HH:MM local time. Leave 0 / blank to disable.
DAILY_REPORT_GROUP=0
DAILY_REPORT_TIME=23:55

# ===== Long-term memory (daily recap per group) =====
# Every day at this time the bot summarises yesterday's group activity into a
# ~100-char "long memory" stored in SQLite. The bot auto-references the most
# recent few days when chatting, so it can casually say "前几天我们聊过..."
DAILY_RECAP_ENABLED=1
DAILY_RECAP_TIME=03:30
DAILY_RECAP_KEEP_DAYS=365
LONG_MEMORY_INJECT_DAYS=3

# ===== Bot policy =====
# Comma-separated QQ group IDs that the bot is allowed to talk in.
ALLOWED_GROUPS=123456789,987654321
# Optional: superusers (QQ ids) that bypass quota.
SUPERUSERS=

# Bot 的 QQ 昵称（router 用来判断消息是否指向 bot）
BOT_NICKNAME=小笨蛋

# 可选：自定义人格文件路径。留空则用 bot/persona.py 里的默认（温柔可爱少女）。
# 文件里可以用 {nickname} 占位符，会被替换成 BOT_NICKNAME。
BOT_PERSONA_FILE=

# ===== Limits (overridable; sensible defaults are in config.py) =====
DAILY_OPENAI_TEXT_GROUP=20
DAILY_OPENAI_TEXT_USER=3
DAILY_OPENAI_IMAGE_GROUP=10
DAILY_OPENAI_IMAGE_USER=2
DAILY_OPENAI_IMAGE_EDIT_GROUP=5
DAILY_OPENAI_IMAGE_EDIT_USER=1
DAILY_OPENAI_VISION_GROUP=20
DAILY_OPENAI_VISION_USER=5
# Background auto-captioning of group images (only consulted when
# AUTO_VISION_GROUP_IMAGES=1 below). Daily cap per group.
AUTO_VISION_DAILY_MAX=100

# ===== Auto-caption =====
# When ON: every image floating through the group gets a quick caption via
# OpenAI vision; caption is stored in group_memory so /recap, proactive bot,
# and chat context all "see" what was sent. ~$0.00003 / image.
AUTO_VISION_GROUP_IMAGES=0

# Per-minute message rate-limit (per user).
RATE_LIMIT_USER_PER_MIN=15

# Reply cost controls.
MAX_REPLY_CHARS=1800
MAX_HISTORY_TURNS=8

# ===== Lessons (unified 功能注入: rules + facts + agreements + reminders) =====
# One LLM classifier per message decides whether the user is teaching:
#   * rule       — behavior to follow forever ("你说话简短点")
#   * fact       — preference / persistent attribute ("我对花生过敏")
#   * agreement  — group decision ("周五开会")
#   * reminder   — scheduled callback ("晚上9点叫我")
# Rows go to a single `lessons` table. Active rows are injected into the
# system prompt on every chat turn; rows with trigger_at fire via the
# reminder loop. Replaces the previous lessons+important_memory split.
LESSONS_ENABLED=1
LESSONS_INJECT_LIMIT=12

# ===== Quoted-image intent gate =====
# When a user replies to a message containing an image, run a cheap
# vision caption first; then route on text+caption so the bot doesn't
# auto-describe images that are just backdrop for a text question.
# Uses auto_vision quota. Disable to revert to "describe every quoted image".
QUOTED_IMAGE_INTENT_GATE=1

# ===== File ingestion =====
# Read text out of attached files (txt/md/csv/json, PDF, docx, code).
# Audio files get transcribed via Whisper; video files get audio
# transcribed + a few evenly-spaced frames captioned (needs ffmpeg).
FILE_INGEST_ENABLED=1
FILE_INGEST_MAX_MB=20
FILE_INGEST_MAX_CHARS=12000
FILE_AUDIO_TRANSCRIBE=1
OPENAI_AUDIO_MODEL=whisper-1
# 0 disables video frame sampling (audio still transcribes).
FILE_VIDEO_FRAME_COUNT=4

# ===== Tool use (LLM-driven function calls) =====
# When ON, every text chat call exposes the bot's tool registry to the LLM —
# currently the `web_search` tool. The model decides when to call a tool
# instead of replying directly. The handler runs up to TOOL_USE_MAX_HOPS
# rounds of tool→result→chat before forcing a final answer. Set to 0 to
# revert to "no tools, training-data cutoff only".
TOOL_USE_ENABLED=1
TOOL_USE_MAX_HOPS=3

# ===== Web search (Tavily-backed `web_search` tool) =====
# Set TAVILY_API_KEY to enable. The tool registers either way — if no key
# is set it returns a polite "search not configured" message rather than
# failing. Free tier: 1000 searches/month at tavily.com.
WEB_SEARCH_ENABLED=1
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# ===== News drop (replaces the old "dreams" feature) =====
# Once a day at NEWS_TIME (in NEWS_TIME_TZ), the bot pulls a broad
# "what's hot today" search via Tavily and lets the LLM filter the results
# against its persona rules (skip CN politics / gossip / disasters; prefer
# tech / science / quirky). The few survivors are folded into one short
# paragraph and posted to every allowed, non-paused group.
# Costs ~$0.001 per post (1 Tavily + 1 DeepSeek per group).
# Any user can force a post on demand with `/news [topic]`.
NEWS_ENABLED=0
NEWS_TIME=09:00
NEWS_TIME_TZ=Asia/Shanghai
NEWS_QUERY=今日热点新闻
NEWS_MIN_INTERVAL_HOURS=20
NEWS_SEARCH_MAX_RESULTS=7

# Logging.
LOG_LEVEL=INFO
