# ===== LLM providers =====
DEEPSEEK_API_KEY=sk-deepseek-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

OPENAI_API_KEY=sk-openai-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
# gpt-image-1-mini low: $0.005/img at 1024x1024 — cheapest + newer than dall-e-2.
# Other options: gpt-image-1 (medium/high, ~$0.01-0.04), dall-e-2 ($0.016 at 256x256).
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_SIZE=1024x1024
# gpt-image-* only: low | medium | high | auto.
OPENAI_IMAGE_QUALITY=low
# Uploaded images are downscaled to fit within this box (px) before being sent
# to the vision API. Cuts cost; quality is fine for OCR + general description.
MAX_VISION_INPUT_SIZE=128

# ===== OneBot v11 (NapCatQQ / Lagrange) =====
# Two modes:
#   forward  — the bot connects out to ONEBOT_WS_URL exposed by the adapter.
#   reverse  — the bot runs a WS server; the adapter connects in. NapCat default.
ONEBOT_MODE=forward
ONEBOT_WS_URL=ws://127.0.0.1:3001
ONEBOT_ACCESS_TOKEN=

# Used only when ONEBOT_MODE=reverse:
ONEBOT_REVERSE_HOST=0.0.0.0
ONEBOT_REVERSE_PORT=3001
ONEBOT_REVERSE_PATH=/onebot/v11/ws

# ===== Trigger mode =====
# always  — reply to every group message (commands always work)
# mention — only when the bot is @ed
# prefix  — only when the message starts with TRIGGER_PREFIX
TRIGGER_MODE=always
TRIGGER_PREFIX=#

# How long (seconds) to keep downloaded image bytes around so /edit and /vision
# can reuse them without re-downloading from QQ (whose URLs may expire).
# Files are persisted to data/images/ and swept on a 10-minute interval.
IMAGE_CACHE_TTL=600

# ===== Streaming =====
# Stream DeepSeek replies into QQ in chunks. Disable on flaky networks.
STREAM_REPLIES=1
STREAM_FLUSH_CHARS=220

# ===== Daily report =====
# Set this to a QQ group id and the bot will post today's usage there at the
# configured HH:MM local time. Leave 0 / blank to disable.
DAILY_REPORT_GROUP=0
DAILY_REPORT_TIME=23:55

# ===== Bot policy =====
# Comma-separated QQ group IDs that the bot is allowed to talk in.
ALLOWED_GROUPS=123456789,987654321
# Optional: superusers (QQ ids) that bypass quota.
SUPERUSERS=

# ===== Limits (overridable; sensible defaults are in config.py) =====
DAILY_OPENAI_TEXT_GROUP=20
DAILY_OPENAI_TEXT_USER=3
DAILY_OPENAI_IMAGE_GROUP=10
DAILY_OPENAI_IMAGE_USER=2
DAILY_OPENAI_IMAGE_EDIT_GROUP=5
DAILY_OPENAI_IMAGE_EDIT_USER=1
DAILY_OPENAI_VISION_GROUP=20
DAILY_OPENAI_VISION_USER=5

# Per-minute message rate-limit (per user).
RATE_LIMIT_USER_PER_MIN=15

# Reply cost controls.
MAX_REPLY_CHARS=1800
MAX_HISTORY_TURNS=8

# Logging.
LOG_LEVEL=INFO
